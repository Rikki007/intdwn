{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)\\.js",
      "headers": [{ "key": "Content-Type", "value": "application/javascript; charset=utf-8" }]
    },
    {
      "source": "/manifest\\.json",
      "headers": [{ "key": "Content-Type", "value": "application/manifest+json; charset=utf-8" }]
    }
  ],
  "routes": [
    { "src": "/.*", "dest": "/index.html" }
  ]
}